# Primus CLI Project Configuration File
# Copy to .primus.yaml in your project root
# Format: YAML
# Priority: CLI arguments > Config file > Default values

# Global settings (apply to all modes)
global:
  debug: false       # Enable debug mode (equivalent to --debug)
  dry_run: false     # Enable dry-run mode (equivalent to --dry-run)

# Direct mode settings (for direct execution without Slurm)
direct:
  gpus_per_node: 8
  master_port: 1234
  nnodes: 1
  # master_addr: localhost

# Container settings
container:
  # Docker/Podman image
  image: "rocm/primus:v25.9_gfx942"
  
  # Docker/Podman runtime options (generic key-value pairs)
  # These will be passed as --key value to docker/podman run
  options:
    cpus: "16"                # --cpus 16
    memory: "128G"            # --memory 128G
    shm-size: "16G"           # --shm-size 16G
    name: "primus-training"   # --name primus-training
    user: "1000:1000"         # --user 1000:1000
    # gpus: "8"               # --gpus 8 (for nvidia-docker)
    # network: "host"         # --network host
    # Any other docker run options can be added here
  
  # Mount points (can be specified as HOST or HOST:CONTAINER)
  mounts:
    - "/data:/data"           # Mount /data from host to /data in container
    - "/output:/output"       # Mount output directory
    # - "/workspace/Primus"   # Mount with same path (when only HOST given)

# Slurm-specific settings
slurm:
  partition: "AIG_Model"
  nodes: 4
  gpus_per_node: 8
  # time_limit: "24:00:00"

# Path settings
paths:
  log_path: "logs"
  data_path: "/data"
  output_path: "/output"
  primus_path: "/workspace/Primus"  # Local Primus repo (will be mounted and installed in container)

# Project-specific settings
# project:
#   name: "my-training-project"
#   description: "GPT model training"
