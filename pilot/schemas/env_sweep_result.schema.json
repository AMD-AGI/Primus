{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primus.ai/pilot/schemas/env_sweep_result.schema.json",
  "title": "EnvSweepResult",
  "description": "Output of inner-loop EnvSweep. See README.md §8.5.",
  "x-status": "stub",
  "type": "object",
  "required": ["sweep_id", "parent_plan", "candidates", "selected_diff"],
  "properties": {
    "sweep_id": {"type": "string"},
    "parent_plan": {"type": "string"},
    "trigger": {"type": "string"},
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "env_diff": {"type": "object"},
          "tps": {"type": "number"},
          "delta_pct": {"type": "number"}
        }
      }
    },
    "selected_diff": {"type": "object"},
    "cost_gpu_h": {"type": "number"}
  }
}
