{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primus.ai/pilot/schemas/plan_graph.schema.json",
  "title": "PlanGraph",
  "description": "Solution-space tree. Backbone of search-space maintenance guarantees. See skills/workflow/plan_graph.md.",
  "x-status": "v1",
  "type": "object",
  "required": ["schema_version", "session_id", "champion", "nodes", "frontier"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "session_id":     {"type": "string"},
    "created_at":     {"type": "string", "description": "ISO8601 timestamp; written once at graph creation."},
    "updated_at":     {"type": "string", "description": "ISO8601 timestamp; rewritten on every persist."},
    "champion": {"type": "string", "description": "plan_id of current baseline"},
    "champion_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["round", "id"],
        "properties": {
          "round": {"type": "integer"},
          "id":    {"type": "string"},
          "at":    {"type": "string"}
        }
      }
    },
    "nodes": {
      "type": "object",
      "description": "Map plan_id \u2192 node record.",
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "parent": {"type": ["string", "null"]},
          "status": {"type": "string", "enum": ["completed", "shelved", "dead", "running"]},
          "tps":    {"type": ["number", "null"]},
          "bottleneck": {"type": ["string", "null"]},
          "champion_at": {"type": "array", "items": {"type": "integer"}},
          "derived_axis": {
            "type": ["object", "null"],
            "description": "(axis, value, type) move that produced this node. null only on the root.",
            "properties": {
              "axis":  {"type": ["string", "null"]},
              "value": {},
              "type":  {"type": ["string", "null"], "enum": ["weakly_local", "strongly_local", "structural", "cluster_shared", "control", null]},
              "composite": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "axis":  {"type": "string"},
                    "value": {},
                    "type":  {"type": "string"}
                  }
                }
              }
            }
          },
          "reason": {"type": "string"},
          "measurement_ref": {"type": ["string", "null"]},
          "round_id": {"type": ["integer", "null"]}
        }
      }
    },
    "frontier": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Currently derivable nodes (champion + shelved)."
    },
    "exhausted_neighborhoods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["around", "axis", "tried"],
        "properties": {
          "around":     {"type": "string"},
          "axis":       {"type": "string"},
          "axis_type":  {"type": ["string", "null"]},
          "tried":      {"type": "array"}
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "rounds_since_promotion": {"type": "integer", "minimum": 0},
        "rounds_since_explore":   {"type": "integer", "minimum": 0},
        "dead_rate_in_subtree":   {"type": "object"},
        "explore_period_K":       {"type": "integer", "minimum": 1}
      }
    }
  }
}
