+# Enable (``1``, default) or disable (``0``) the identity-sort short-circuit
+# in MoE token dispatch / combine. Read once at module import; to toggle, set
+# the env var before launching the training process.
+_MOE_SKIP_IDENTITY_SORT_ENABLED = os.environ.get("MOE_SKIP_IDENTITY_SORT", "1") != "0"
+
+
+def _is_identity_local_expert_sort(idx: Optional[torch.Tensor]) -> bool:
+    """Return True if ``idx`` is the identity permutation ``[0, 1, ..., N-1]``.
+
+    When the MoE topology yields ``sort_input_by_local_experts`` (and its
+    inverse ``restore_output_by_local_experts``) equal to ``arange(N)``,
+    ``sort_chunks_by_idxs`` reduces to a full-tensor memcopy with no useful
+    reordering. Typical trigger is ``EP=1`` / ``TP=1`` with the default
+    routing; the index is a function of the EP/TP topology only, so this
+    property is stable across iterations and can be cached per dispatcher.
+    """
+    if not _MOE_SKIP_IDENTITY_SORT_ENABLED or idx is None or idx.dim() != 1 or idx.numel() == 0:
+        return False
+    return bool(torch.equal(idx, torch.arange(idx.numel(), device=idx.device, dtype=idx.dtype)))
+
